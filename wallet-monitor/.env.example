# wallet-monitor/.env — copy to wallet-monitor/.env and fill in.
# (.env is gitignored; only this .env.example template is committed.)

# REQUIRED — Slack Incoming Webhook URL alerts are POSTed to.
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# OPTIONAL — Ogmios HTTP endpoint used to read balances.
# Defaults to the mainnet public endpoint (also pinned in the compose file).
# OGMIOS_URL=https://ogmios.vector.mainnet.apexfusion.org

# OPTIONAL — override the wallets.json default threshold / reminder cadence
# without editing the mounted wallets file.
# DEFAULT_MIN_AP3X=10
# REMINDER_HOURS=6

# OPTIONAL — paths inside the container (defaults shown; bind-mounted by compose).
# WALLETS_PATH=/repo/wallet-monitor/wallets.json
# STATE_PATH=/repo/wallet-monitor/data/state.json
